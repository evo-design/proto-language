{
  "name": "metal3d_ligandmpnn_ga",
  "description": "Compact enzyme-design example based on the dEVA Metal3D workflow. The program starts from the zinc-binding 2VVB scaffold, runs LigandMPNN scaffold-conditioned initialization, then uses a generic genetic algorithm with dEVA-style two-point crossover and proposal-structure MPNN-guided offspring mutation. Each proposal is scored as two NSGA-II objectives: LigandMPNN sequence probability and Metal3D-Cat probability on the current proposal structure.",
  "version": "1.0",
  "num_results": 2,
  "constructs": [
    {
      "id": "construct1",
      "type": "protein",
      "label": "2VVB zinc-binding enzyme scaffold",
      "segments": [
        {
          "id": "enzyme_chain",
          "label": "2VVB chain X",
          "sequence": "HHWGYGKHNGPEHWHKDFPIAKGERQSPVDIDTHTAKYDPSLKPLSVSYDQATSLRILNNGHAFNVEFDDSQDKAVLKGGPLDGTYRLIQFHFHWGSLDGQGSEHTVDKKKYAAELHLVHWNTKYGDFGKAVQQPDGLAVLGIFLKVGSAKPGLQKVVDVLDSIKTKGKSADFTNFDPRGLLPESLDYWTYPGSLTTPPLLECVTWIVLKEPISVSSEQVLKFRKLNFNGEGEPEELMVDNWRPAQPLKNRQIKASFK"
        }
      ]
    }
  ],
  "optimization_stages": [
    {
      "generators": [
        {
          "key": "ligandmpnn",
          "label": "LigandMPNN scaffold-conditioned sequence design",
          "targets": ["enzyme_chain"],
          "config": {
            "structure_inputs": [
              {
                "structure": "https://raw.githubusercontent.com/gelnesr/dEVA/main/inputs/2VVB.pdb"
              }
            ],
            "temperature": 0.5,
            "excluded_amino_acids": ["C"],
            "ligand_mpnn_use_side_chain_context": true,
            "ligand_mpnn_cutoff_for_score": 20.0,
            "backend": "foundry",
            "tool_seed": 0,
            "batch_size": 4,
            "device": "cuda",
            "verbose": false
          }
        },
        {
          "key": "mpnn-mutation",
          "label": "LigandMPNN offspring mutation",
          "targets": [
            "enzyme_chain"
          ],
          "config": {
            "model": "ligandmpnn",
            "structure_source": "proposal_structure",
            "structure_inputs": [
              {
                "structure": "https://raw.githubusercontent.com/gelnesr/dEVA/main/inputs/2VVB.pdb",
                "chains_to_redesign": ["X"]
              }
            ],
            "output_chain_id": "X",
            "num_mutations": 4,
            "excluded_amino_acids": ["C"],
            "replacement_strategy": "argmax",
            "replacement_temperature": 1.0,
            "ligand_mpnn_use_side_chain_context": true,
            "ligand_mpnn_cutoff_for_score": 20.0,
            "ligand_mpnn_backend": "foundry",
            "ligand_mpnn_tool_seed": 0,
            "rng_mode": "global",
            "rng_seed": 0,
            "post_mutation_score_mode": "autoregressive",
            "post_mutation_structure_preparation": {
              "mode": "ligandmpnn_pack_from_proposal",
              "chain_ids": ["X"],
              "ligandmpnn_pack_config": {
                "temperature": 0.5,
                "ligand_mpnn_use_side_chain_context": true,
                "ligand_mpnn_cutoff_for_score": 20.0,
                "backend": "foundry",
                "seed": 0,
                "batch_size": 1,
                "device": "cuda",
                "verbose": false
              }
            },
            "device": "cuda",
            "verbose": false
          }
        }
      ],
      "constraints": [
        {
          "key": "mpnn-sequence-probability",
          "label": "LigandMPNN sequence probability",
          "targets": ["enzyme_chain"],
          "weight": 1.0,
          "config": {
            "model": "ligandmpnn",
            "structure_source": "proposal_structure",
            "structure_inputs": [
              {
                "structure": "https://raw.githubusercontent.com/gelnesr/dEVA/main/inputs/2VVB.pdb",
                "chains_to_redesign": ["X"]
              }
            ],
            "output_chain_id": "X",
            "score_mode": "probability_loss",
            "score_source": "model",
            "ligand_mpnn_use_side_chain_context": true,
            "ligand_mpnn_cutoff_for_score": 20.0,
            "ligand_mpnn_backend": "foundry",
            "device": "cuda",
            "verbose": false
          }
        },
        {
          "key": "metal3d-probability",
          "label": "Metal3D-Cat metal-site probability",
          "targets": ["enzyme_chain"],
          "weight": 1.0,
          "config": {
            "min_probability": 0.2,
            "structure_preparation": {
              "mode": "proposal_structure"
            },
            "metal3d_config": {
              "model_checkpoint": "metal3d-cat",
              "cluster_distance_threshold": 7.0,
              "max_sites": 8,
              "device": "cuda",
              "verbose": false
            }
          }
        }
      ],
      "optimizer": {
        "method": "genetic-algorithm",
        "config": {
          "num_generations": 5,
          "num_results": 2,
          "population_size": 2,
          "offspring_per_generation": 2,
          "elite_fraction": 0.25,
          "crossover_rate": 1.0,
          "crossover_strategy": "two_point",
          "parent_selection": "tournament",
          "parent_pair_selection": "shared_tournament",
          "tournament_size": 2,
          "tournament_win_probability": 0.9,
          "require_distinct_parents": true,
          "offspring_pairing": "reciprocal",
          "replacement": "elitist",
          "survivor_selection": "nsga2",
          "crossover_excluded_positions": {
            "2VVB chain X": [0, 1, 2, 3, 4]
          },
          "crossover_allow_empty_region": true,
          "preserve_parent_structure_after_crossover": true,
          "refine_offspring_with_generators": false,
          "initialize_with_mutation_generators": false,
          "tracking_interval": 1,
          "track_proposals": false,
          "verbose": false,
          "seed": 0
        }
      }
    }
  ]
}
