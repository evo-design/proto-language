{
  "name": "metal3d_fampnn_ga",
  "description": "Compact enzyme-design example based on the dEVA Metal3D workflow. The program starts from the zinc-binding 2VVB scaffold, reproduces the literal dEVA 2VVB mutability behavior where chain X is fully designable, then runs a generic genetic algorithm with whole-chain crossover and MPNN-guided offspring mutation. Each proposal is threaded onto the scaffold, sidechain-packed with FAMPNN, and scored by Metal3D-Cat over the default canonical metal-binding residue candidates.",
  "version": "1.0",
  "num_results": 2,
  "constructs": [
    {
      "id": "construct1",
      "type": "protein",
      "label": "2VVB zinc-binding enzyme scaffold",
      "segments": [
        {
          "id": "enzyme_chain",
          "label": "2VVB chain X",
          "sequence": "HHWGYGKHNGPEHWHKDFPIAKGERQSPVDIDTHTAKYDPSLKPLSVSYDQATSLRILNNGHAFNVEFDDSQDKAVLKGGPLDGTYRLIQFHFHWGSLDGQGSEHTVDKKKYAAELHLVHWNTKYGDFGKAVQQPDGLAVLGIFLKVGSAKPGLQKVVDVLDSIKTKGKSADFTNFDPRGLLPESLDYWTYPGSLTTPPLLECVTWIVLKEPISVSSEQVLKFRKLNFNGEGEPEELMVDNWRPAQPLKNRQIKASFK"
        }
      ]
    }
  ],
  "optimization_stages": [
    {
      "generators": [
        {
          "key": "ligandmpnn",
          "label": "LigandMPNN scaffold-conditioned sequence design",
          "targets": ["enzyme_chain"],
          "config": {
            "structure_inputs": [
              {
                "structure": "https://raw.githubusercontent.com/gelnesr/dEVA/main/inputs/2VVB.pdb"
              }
            ],
            "temperature": 0.5,
            "excluded_amino_acids": ["C"],
            "batch_size": 4,
            "device": "cuda",
            "verbose": false
          }
        },
        {
          "key": "mpnn-mutation",
          "label": "LigandMPNN offspring mutation",
          "targets": [
            "enzyme_chain"
          ],
          "config": {
            "model": "ligandmpnn",
            "structure_inputs": [
              {
                "structure": "https://raw.githubusercontent.com/gelnesr/dEVA/main/inputs/2VVB.pdb",
                "chains_to_redesign": ["X"]
              }
            ],
            "output_chain_id": "X",
            "num_mutations": 4,
            "excluded_amino_acids": ["C"],
            "replacement_strategy": "sample",
            "replacement_temperature": 1.0,
            "device": "cuda",
            "verbose": false
          }
        }
      ],
      "constraints": [
        {
          "key": "metal3d-probability",
          "label": "Metal3D-Cat metal-site probability",
          "targets": ["enzyme_chain"],
          "weight": 1.0,
          "config": {
            "min_probability": 0.2,
            "structure_preparation": {
              "mode": "fampnn_pack_from_scaffold",
              "scaffold_structure": "https://raw.githubusercontent.com/gelnesr/dEVA/main/inputs/2VVB.pdb",
              "chain_ids": ["X"],
              "fampnn_pack_config": {
                "model_variant": "0.0",
                "num_samples_per_structure": 1,
                "batch_size": 4,
                "scn_diffusion_steps": 8,
                "scn_step_scale": 1.5,
                "device": "cuda",
                "verbose": false
              }
            },
            "metal3d_config": {
              "model_checkpoint": "metal3d-cat",
              "cluster_distance_threshold": 7.0,
              "max_sites": 8,
              "device": "cuda",
              "verbose": false
            }
          }
        }
      ],
      "optimizer": {
        "method": "genetic-algorithm",
        "config": {
          "num_generations": 5,
          "num_results": 2,
          "population_size": 2,
          "offspring_per_generation": 2,
          "elite_fraction": 0.25,
          "crossover_rate": 1.0,
          "crossover_strategy": "two_point",
          "parent_selection": "tournament",
          "tournament_size": 2,
          "replacement": "elitist",
          "refine_offspring_with_generators": false,
          "initialize_with_mutation_generators": false,
          "tracking_interval": 1,
          "track_proposals": false,
          "verbose": false,
          "seed": 0
        }
      }
    }
  ]
}
